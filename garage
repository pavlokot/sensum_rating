
<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>WhiteGarage — Авторемонт · Шиномонтаж · Доставка авто з США</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
:root {
  --navy: #0A0F1E;
  --blue: #2563EB;
  --blue-light: #3B82F6;
  --frost: #F5F7FA;
  --steel: #64748B;
  --white: #FFFFFF;
  --border: rgba(255,255,255,0.08);
  --border-light: rgba(10,15,30,0.1);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Manrope',sans-serif;background:var(--navy);color:var(--white);overflow-x:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:1.25rem 2.5rem;display:flex;justify-content:space-between;align-items:center;background:rgba(10,15,30,0.85);backdrop-filter:blur(12px);border-bottom:0.5px solid var(--border)}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.nav-logo svg{width:28px;height:28px}
.nav-logo-text{font-size:18px;font-weight:600;color:var(--white);letter-spacing:-.01em}
.nav-logo-text span{color:var(--blue)}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{color:rgba(255,255,255,0.6);text-decoration:none;font-size:14px;font-weight:500;transition:color .2s}
.nav-links a:hover{color:var(--white)}
.nav-cta{background:var(--blue);color:var(--white);padding:8px 20px;border-radius:8px;font-size:14px;font-weight:600;text-decoration:none;transition:background .2s}
.nav-cta:hover{background:var(--blue-light)}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 2.5rem 5rem;position:relative;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:linear-gradient(135deg,#0A0F1E 0%,#0f1a2e 50%,#0A0F1E 100%)}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(37,99,235,0.06) 1px,transparent 1px),linear-gradient(90deg,rgba(37,99,235,0.06) 1px,transparent 1px);background-size:60px 60px;animation:gridMove 20s linear infinite}
@keyframes gridMove{0%{transform:translateY(0)}100%{transform:translateY(60px)}}
.hero-accent{position:absolute;top:15%;right:5%;width:480px;height:480px;background:radial-gradient(circle,rgba(37,99,235,0.15) 0%,transparent 70%);pointer-events:none}
.hero-label{font-size:12px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--blue);margin-bottom:1rem;opacity:0;animation:fadeUp .6s .2s forwards}
.hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(72px,10vw,130px);line-height:.95;letter-spacing:-.01em;margin-bottom:1.5rem;opacity:0;animation:fadeUp .7s .3s forwards}
.hero-title span{color:var(--blue)}
.hero-sub{font-size:18px;color:rgba(255,255,255,0.55);max-width:480px;line-height:1.6;margin-bottom:2.5rem;opacity:0;animation:fadeUp .7s .4s forwards}
.hero-actions{display:flex;gap:1rem;align-items:center;opacity:0;animation:fadeUp .7s .5s forwards}
.btn-primary{background:var(--blue);color:var(--white);padding:14px 28px;border-radius:10px;font-size:15px;font-weight:600;text-decoration:none;transition:all .2s;display:inline-flex;align-items:center;gap:8px}
.btn-primary:hover{background:var(--blue-light);transform:translateY(-1px)}
.btn-secondary{color:rgba(255,255,255,0.7);font-size:15px;font-weight:500;text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:color .2s}
.btn-secondary:hover{color:var(--white)}
.hero-stats{position:absolute;right:2.5rem;bottom:5rem;display:flex;flex-direction:column;gap:1.5rem;opacity:0;animation:fadeLeft .8s .6s forwards}
.stat{text-align:right}
.stat-num{font-family:'Bebas Neue',sans-serif;font-size:48px;color:var(--white);line-height:1}
.stat-num span{color:var(--blue)}
.stat-label{font-size:12px;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:.08em}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeLeft{from{opacity:0;transform:translateX(24px)}to{opacity:1;transform:translateX(0)}}

/* TRUST BAR */
.trust-bar{background:#111827;border-top:0.5px solid var(--border);border-bottom:0.5px solid var(--border);padding:1.25rem 2.5rem;display:flex;justify-content:center;gap:3rem;flex-wrap:wrap}
.trust-item{display:flex;align-items:center;gap:10px;font-size:14px;color:rgba(255,255,255,0.55);font-weight:500}
.trust-item svg{color:var(--blue);flex-shrink:0}

/* SECTION BASE */
section{padding:6rem 2.5rem}
.section-label{font-size:12px;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--blue);margin-bottom:.75rem}
.section-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(42px,5vw,64px);line-height:1;margin-bottom:1.5rem}
.section-sub{font-size:16px;color:rgba(255,255,255,0.5);line-height:1.7;max-width:520px}

/* SERVICES */
.services-section{background:var(--frost);color:var(--navy)}
.services-section .section-label{color:var(--blue)}
.services-section .section-title{color:var(--navy)}
.services-section .section-sub{color:var(--steel)}
.services-top{display:flex;justify-content:space-between;align-items:flex-start;gap:2rem;flex-wrap:wrap;margin-bottom:3rem}
.services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem}
.service-card{background:var(--white);border-radius:16px;padding:2rem;border:0.5px solid var(--border-light);transition:all .25s;position:relative;overflow:hidden}
.service-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--blue);transform:scaleX(0);transform-origin:left;transition:transform .3s}
.service-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(37,99,235,0.12)}
.service-card:hover::before{transform:scaleX(1)}
.service-icon{width:48px;height:48px;background:#EFF6FF;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem}
.service-icon svg{width:24px;height:24px;color:var(--blue)}
.service-name{font-size:20px;font-weight:700;color:var(--navy);margin-bottom:.5rem}
.service-desc{font-size:14px;color:var(--steel);line-height:1.6}
.service-items{list-style:none;margin-top:1rem;display:flex;flex-direction:column;gap:6px}
.service-items li{font-size:13px;color:var(--steel);display:flex;align-items:center;gap:8px}
.service-items li::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--blue);flex-shrink:0}

/* MAP + CONTACTS */
.contacts-row{display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-top:3rem}
.contact-card{background:var(--white);border-radius:16px;padding:2rem;border:0.5px solid var(--border-light)}
.contact-card h3{font-size:18px;font-weight:700;color:var(--navy);margin-bottom:1.25rem}
.contact-item{display:flex;align-items:flex-start;gap:12px;margin-bottom:1rem}
.contact-icon{width:36px;height:36px;background:#EFF6FF;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.contact-icon svg{width:18px;height:18px;color:var(--blue)}
.contact-text{font-size:14px;color:var(--steel);line-height:1.5}
.contact-text strong{display:block;font-size:15px;color:var(--navy);font-weight:600;margin-bottom:2px}
.phone-big{font-family:'Bebas Neue',sans-serif;font-size:36px;color:var(--navy);letter-spacing:.02em;text-decoration:none;display:block;margin-top:.5rem;transition:color .2s}
.phone-big:hover{color:var(--blue)}
.map-placeholder{background:#E8F0FE;border-radius:12px;height:200px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem;margin-top:1rem;border:0.5px solid var(--border-light);position:relative;overflow:hidden}
.map-placeholder::before{content:'';position:absolute;inset:0;background:url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40"><path d="M0 20h40M20 0v40" stroke="%232563EB" stroke-width=".3" opacity=".3"/></svg>') repeat}
.map-pin{width:36px;height:36px;background:var(--blue);border-radius:50% 50% 50% 0;transform:rotate(-45deg);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 12px rgba(37,99,235,0.4)}
.map-pin::after{content:'';width:12px;height:12px;background:white;border-radius:50%;transform:rotate(45deg)}
.map-address{font-size:13px;color:var(--steel);font-weight:500;text-align:center;z-index:1}
.map-link{font-size:13px;color:var(--blue);font-weight:600;text-decoration:none;z-index:1}

/* CARS */
.cars-section{background:var(--navy)}
.cars-intro{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:3rem;gap:2rem;flex-wrap:wrap}
.exp-badge{background:rgba(37,99,235,0.15);border:0.5px solid rgba(37,99,235,0.3);border-radius:12px;padding:1.25rem 1.75rem;text-align:center}
.exp-num{font-family:'Bebas Neue',sans-serif;font-size:56px;color:var(--blue);line-height:1}
.exp-label{font-size:13px;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:.08em}
.cars-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-bottom:3rem}
.car-card{border-radius:14px;overflow:hidden;position:relative;aspect-ratio:4/3;background:#111827;border:0.5px solid var(--border)}
.car-card img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
.car-card:hover img{transform:scale(1.04)}
.car-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(10,15,30,0.8) 0%,transparent 50%)}
.car-label{position:absolute;bottom:1rem;left:1rem;right:1rem}
.car-name{font-size:15px;font-weight:700;color:var(--white)}
.car-meta{font-size:12px;color:rgba(255,255,255,0.55);margin-top:2px}
.car-badge{position:absolute;top:.75rem;right:.75rem;padding:4px 10px;border-radius:20px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em}
.badge-available{background:rgba(34,197,94,0.2);color:#4ade80;border:0.5px solid rgba(34,197,94,0.3)}
.badge-transit{background:rgba(37,99,235,0.2);color:#60a5fa;border:0.5px solid rgba(37,99,235,0.3)}

/* car image fallbacks with gradients */
.car-img-1{background:linear-gradient(135deg,#1a2744 0%,#243460 100%)}
.car-img-2{background:linear-gradient(135deg,#1c1f2e 0%,#2a2d3e 100%)}
.car-img-3{background:linear-gradient(135deg,#162030 0%,#1e3048 100%)}
.car-img-4{background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%)}
.car-img-5{background:linear-gradient(135deg,#0f2027 0%,#203a43 100%)}

.car-svg-wrapper{width:100%;height:100%;display:flex;align-items:center;justify-content:center;padding:20px}

.pillars-row{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:1rem}
.pillar-card{background:rgba(255,255,255,0.04);border:0.5px solid var(--border);border-radius:14px;padding:1.5rem}
.pillar-icon-wrap{font-size:24px;margin-bottom:.75rem}
.pillar-title{font-size:15px;font-weight:700;margin-bottom:.4rem}
.pillar-desc{font-size:13px;color:rgba(255,255,255,0.45);line-height:1.6}

/* FOOTER */
footer{background:#060a14;border-top:0.5px solid var(--border);padding:3rem 2.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:gap:1rem}
.footer-logo{display:flex;align-items:center;gap:10px}
.footer-logo-text{font-size:16px;font-weight:600;color:var(--white)}
.footer-logo-text span{color:var(--blue)}
.footer-copy{font-size:13px;color:rgba(255,255,255,0.3)}

/* RESPONSIVE */
@media(max-width:768px){
  .contacts-row,.cars-grid,.pillars-row{grid-template-columns:1fr}
  .hero-stats{display:none}
  nav .nav-links{display:none}
  .cars-intro{flex-direction:column}
  .hero-title{font-size:clamp(56px,12vw,90px)}
}
</style>
</head>
